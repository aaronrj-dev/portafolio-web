---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="bg-espresso-900 text-bone-100">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-5 py-14 sm:px-8 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="font-display text-3xl font-semibold text-white">{site.name}</p>
      <p class="mt-2 text-bone-100/70">{site.role} · {site.location}</p>
    </div>
    <div class="flex flex-col gap-2 text-sm md:items-end">
      <a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a>
      <div class="flex gap-4">
        <a href={site.social.instagram} rel="noopener" target="_blank" class="hover:text-white">Instagram</a>
        <a href={site.social.behance} rel="noopener" target="_blank" class="hover:text-white">Behance</a>
      </div>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-5 text-xs text-bone-100/50 sm:flex-row sm:px-8">
      <p>© {year} {site.name}. Todos los derechos reservados.</p>
      <p>Diseño y desarrollo · <a href="mailto:aaronrj.webdev@gmail.com" class="underline hover:text-white">Aaron RJ</a></p>
    </div>
  </div>
</footer>
