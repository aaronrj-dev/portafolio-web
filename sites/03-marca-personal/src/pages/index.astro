---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import { site, services, portfolio, testimonials, steps, faqs } from "../data/site";

const tags = ["Todo", "Bodas", "Retrato", "Marca"] as const;
---

<BaseLayout>
  <span id="top"></span>
  <Header />

  <main id="main">
    <!-- ================= HERO ================= -->
    <section class="relative flex min-h-[94vh] items-center overflow-hidden">
      <img src={site.images.hero} alt="Fotografía de boda al atardecer" fetchpriority="high" class="absolute inset-0 h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-espresso-900/85 via-espresso-900/45 to-espresso-900/60"></div>

      <div class="relative mx-auto w-full max-w-6xl px-5 sm:px-8">
        <div class="max-w-2xl text-white">
          <p class="reveal text-sm font-medium uppercase tracking-[0.25em] text-bone-100/90">{site.role}</p>
          <h1 class="reveal mt-5 font-display text-4xl font-semibold leading-[1.08] sm:text-6xl">
            {site.headline}
          </h1>
          <p class="reveal mt-6 max-w-xl text-lg text-bone-100/90">{site.sub}</p>
          <div class="reveal mt-9 flex flex-col gap-3 sm:flex-row">
            <a href="#contacto" class="rounded-full bg-ochre-500 px-8 py-3.5 text-center font-medium text-white shadow-lg transition-transform hover:-translate-y-0.5 hover:bg-ochre-600">
              Reserva tu sesión
            </a>
            <a href="#portfolio" class="rounded-full border border-white/40 px-8 py-3.5 text-center font-medium text-white backdrop-blur-sm transition-colors hover:bg-white/10">
              Ver portfolio
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================= CONFIANZA ================= -->
    <section class="border-b border-bone-200 bg-bone-50">
      <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-5 py-10 text-center sm:grid-cols-4 sm:px-8">
        {[
          { n: "+150", l: "bodas fotografiadas" },
          { n: "8 años", l: "de experiencia" },
          { n: "4,9★", l: "valoración media" },
          { n: "48 h", l: "en responder" },
        ].map((s) => (
          <div class="reveal">
            <p class="font-display text-3xl font-semibold text-ochre-600">{s.n}</p>
            <p class="mt-1 text-sm text-ink-soft">{s.l}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ================= SERVICIOS ================= -->
    <section id="servicios" class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <header class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-ochre-600">Servicios</p>
        <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Cómo puedo ayudarte</h2>
        <p class="mt-4 text-ink-soft">Precios orientativos. Cada proyecto se presupuesta a medida.</p>
      </header>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {
          services.map((s) => (
            <article class="reveal flex flex-col rounded-3xl border border-bone-200 bg-white p-7">
              <div class="flex items-baseline justify-between">
                <h3 class="font-display text-2xl font-semibold text-ink">{s.title}</h3>
                <span class="text-sm font-medium text-ochre-600">{s.price}</span>
              </div>
              <p class="mt-3 text-ink-soft">{s.text}</p>
              <ul class="mt-5 flex-1 space-y-2.5 text-sm">
                {s.features.map((f) => (
                  <li class="flex items-start gap-2.5">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-ochre-500" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span class="text-ink-soft">{f}</span>
                  </li>
                ))}
              </ul>
              <a href="#contacto" class="mt-7 inline-flex items-center gap-2 font-medium text-ink hover:text-ochre-600">
                Más info
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <!-- ================= PORTFOLIO ================= -->
    <section id="portfolio" class="bg-bone-100 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <header class="reveal mx-auto max-w-2xl text-center">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-ochre-600">Portfolio</p>
          <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Trabajo reciente</h2>
        </header>

        <!-- Filtros -->
        <div class="reveal mt-8 flex flex-wrap justify-center gap-2" role="group" aria-label="Filtrar por tipo">
          {
            tags.map((t, i) => (
              <button
                type="button"
                data-filter={t}
                class="rounded-full border border-bone-200 px-4 py-2 text-sm font-medium text-ink-soft transition-colors hover:border-ochre-500 aria-pressed:bg-ink aria-pressed:text-white aria-pressed:border-ink"
                aria-pressed={i === 0 ? "true" : "false"}
              >
                {t}
              </button>
            ))
          }
        </div>

        <div class="mt-10 grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-4" data-gallery>
          {
            portfolio.map((s) => (
              <figure
                class:list={["reveal group relative overflow-hidden rounded-2xl bg-bone-200", s.wide && "col-span-2"]}
                data-item
                data-tag={s.tag}
              >
                <img
                  src={s.image}
                  alt={s.alt}
                  loading="lazy"
                  decoding="async"
                  class="w-full object-cover transition-transform duration-700 group-hover:scale-105"
                  style={s.wide ? "aspect-ratio:16/10" : "aspect-ratio:4/5"}
                />
                <figcaption class="absolute bottom-3 left-3 rounded-full bg-espresso-900/70 px-3 py-1 text-xs font-medium text-white opacity-0 backdrop-blur transition-opacity group-hover:opacity-100">
                  {s.tag}
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= SOBRE MÍ ================= -->
    <section id="sobre-mi" class="mx-auto grid max-w-6xl items-center gap-12 px-5 py-20 sm:px-8 sm:py-28 md:grid-cols-2">
      <div class="reveal overflow-hidden rounded-3xl">
        <img src={site.images.about} alt="Retrato de Clara Ferré" loading="lazy" class="w-full object-cover" style="aspect-ratio:4/5" />
      </div>
      <div class="reveal">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-ochre-600">Sobre mí</p>
        <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Hola, soy Clara</h2>
        <p class="mt-6 leading-relaxed text-ink-soft">
          Llevo ocho años haciendo fotos y sigo emocionándome como el primer día. Me interesa
          lo que pasa cuando bajas la guardia: la risa de verdad, la mano que busca otra mano,
          la luz de las seis de la tarde.
        </p>
        <p class="mt-4 leading-relaxed text-ink-soft">
          Trabajo sin postureo ni sesiones interminables. Preparo todo para que tú solo tengas
          que estar, y yo me encargo del resto.
        </p>
        <a href="#contacto" class="mt-8 inline-flex rounded-full bg-ink px-7 py-3.5 font-medium text-white transition-colors hover:bg-espresso-900">
          Cuéntame tu proyecto
        </a>
      </div>
    </section>

    <!-- ================= PROCESO ================= -->
    <section class="bg-espresso-900 py-20 text-bone-100 sm:py-28">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <header class="reveal mx-auto max-w-2xl text-center">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-ochre-400">Cómo trabajo</p>
          <h2 class="mt-3 font-display text-4xl font-semibold text-white sm:text-5xl">Sencillo, de principio a fin</h2>
        </header>
        <div class="mt-14 grid gap-8 md:grid-cols-3">
          {
            steps.map((s) => (
              <div class="reveal">
                <p class="font-display text-5xl font-semibold text-ochre-400/60">{s.n}</p>
                <h3 class="mt-3 font-display text-2xl font-semibold text-white">{s.title}</h3>
                <p class="mt-2 text-bone-100/75">{s.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= OPINIONES ================= -->
    <section id="opiniones" class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <header class="reveal mx-auto max-w-2xl text-center">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-ochre-600">Opiniones</p>
        <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Lo que dicen mis clientes</h2>
      </header>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          testimonials.map((t) => (
            <figure class="reveal flex flex-col rounded-3xl border border-bone-200 bg-white p-7">
              <div class="text-ochre-500" aria-hidden="true">★★★★★</div>
              <blockquote class="mt-4 flex-1 font-display text-lg italic leading-relaxed text-ink">“{t.quote}”</blockquote>
              <figcaption class="mt-6 text-sm">
                <p class="font-medium text-ink">{t.author}</p>
                <p class="text-ink-soft">{t.detail}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <!-- ================= FAQ ================= -->
    <section class="bg-bone-100 py-20 sm:py-24">
      <div class="mx-auto max-w-3xl px-5 sm:px-8">
        <header class="reveal text-center">
          <h2 class="font-display text-3xl font-semibold sm:text-4xl">Preguntas frecuentes</h2>
        </header>
        <div class="reveal mt-10 divide-y divide-bone-200 border-y border-bone-200">
          {
            faqs.map((f) => (
              <details class="group py-5">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-ink">
                  {f.q}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="shrink-0 text-ochre-500 transition-transform group-open:rotate-45" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </summary>
                <p class="mt-3 text-ink-soft">{f.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= CONTACTO ================= -->
    <section id="contacto" class="mx-auto max-w-2xl px-5 py-20 sm:px-8 sm:py-28">
      <header class="reveal text-center">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-ochre-600">Contacto</p>
        <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Cuéntame qué tienes en mente</h2>
        <p class="mt-4 text-ink-soft">Te respondo en menos de 48 h con ideas y presupuesto. Sin compromiso.</p>
      </header>

      <!-- Formulario listo para Formspree (ver INTEGRACIONES.md). Campos mínimos: más conversión. -->
      <form action="https://formspree.io/f/your-form-id" method="POST" class="reveal mt-10 grid gap-5">
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-ink">Nombre</span>
            <input type="text" name="nombre" required autocomplete="name" class="mt-1.5 w-full rounded-xl border border-bone-200 bg-white px-4 py-3 outline-none focus:border-ochre-500" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-ink">Email</span>
            <input type="email" name="email" required autocomplete="email" class="mt-1.5 w-full rounded-xl border border-bone-200 bg-white px-4 py-3 outline-none focus:border-ochre-500" />
          </label>
        </div>
        <label class="block">
          <span class="text-sm font-medium text-ink">¿Qué tipo de sesión?</span>
          <select name="tipo" class="mt-1.5 w-full rounded-xl border border-bone-200 bg-white px-4 py-3 outline-none focus:border-ochre-500">
            <option>Boda</option>
            <option>Retrato / familia</option>
            <option>Marca personal</option>
            <option>Otra cosa</option>
          </select>
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink">Cuéntame un poco</span>
          <textarea name="mensaje" rows="4" placeholder="Fecha aproximada, lugar, qué te gustaría…" class="mt-1.5 w-full rounded-xl border border-bone-200 bg-white px-4 py-3 outline-none focus:border-ochre-500"></textarea>
        </label>
        <button type="submit" class="rounded-full bg-ochre-500 px-8 py-4 font-medium text-white transition-transform hover:-translate-y-0.5 hover:bg-ochre-600">
          Enviar mensaje
        </button>
        <p class="text-center text-xs text-ink-soft">O escríbeme directamente a <a href={`mailto:${site.email}`} class="underline">{site.email}</a></p>
      </form>
    </section>
  </main>

  <Footer />
  <WhatsAppButton />

  <!-- Filtro del portfolio -->
  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const items = document.querySelectorAll<HTMLElement>("[data-item]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter;
        buttons.forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
        items.forEach((it) => {
          const show = filter === "Todo" || it.dataset.tag === filter;
          it.style.display = show ? "" : "none";
        });
      });
    });
  </script>
</BaseLayout>
