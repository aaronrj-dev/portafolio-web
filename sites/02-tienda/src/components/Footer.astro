---
import { site } from "../data/site";
import { categories } from "../data/products";
const year = new Date().getFullYear();
---

<footer class="mt-8 border-t border-cream-200 bg-cream-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:px-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <p class="font-display text-2xl font-semibold text-forest-700">{site.name}</p>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-ink-soft">
        {site.description}
      </p>
      <div class="mt-4 flex gap-4 text-sm">
        <a href={site.social.instagram} rel="noopener" target="_blank" class="text-ink-soft hover:text-forest-700">Instagram</a>
        <a href={site.social.tiktok} rel="noopener" target="_blank" class="text-ink-soft hover:text-forest-700">TikTok</a>
      </div>
    </div>

    <div class="text-sm">
      <h2 class="font-medium text-ink">Tienda</h2>
      <ul class="mt-3 space-y-2 text-ink-soft">
        {
          categories.map((c) => (
            <li>
              <a href={`/tienda#${c.id}`} class="hover:text-forest-700">{c.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="text-sm">
      <h2 class="font-medium text-ink">Contacto</h2>
      <ul class="mt-3 space-y-2 text-ink-soft">
        <li><a href={`mailto:${site.email}`} class="hover:text-forest-700">{site.email}</a></li>
        <li>{site.phone}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-cream-200">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-5 text-xs text-ink-soft sm:flex-row sm:px-8">
      <p>© {year} {site.name}. Cosmética natural hecha en España.</p>
      <p>Diseño y desarrollo · <a href="mailto:aaronrj.webdev@gmail.com" class="underline hover:text-forest-700">Aaron RJ</a></p>
    </div>
  </div>
</footer>
