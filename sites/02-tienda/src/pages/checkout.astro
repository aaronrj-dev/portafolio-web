---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Finalizar compra" description="Checkout de demostración.">
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <a href="/tienda" class="text-sm text-ink-soft underline hover:text-forest-700">← Seguir comprando</a>
    <h1 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Finalizar compra</h1>

    <!-- Aviso de demo -->
    <p class="mt-4 rounded-2xl border border-clay-500/30 bg-clay-500/10 px-4 py-3 text-sm text-ink-soft">
      <strong class="text-ink">Checkout de demostración.</strong> No se procesa ningún pago real.
      En producción se conecta con Stripe (ver <code>INTEGRACIONES.md</code>).
    </p>

    <div class="mt-8 grid gap-10 lg:grid-cols-[1fr_380px]">
      <!-- Formulario -->
      <form id="checkout-form" class="grid gap-6" novalidate>
        <fieldset class="grid gap-4">
          <legend class="font-display text-2xl font-semibold text-forest-700">Contacto y envío</legend>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-sm font-medium">Nombre</span>
              <input required name="nombre" autocomplete="given-name" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
            </label>
            <label class="block">
              <span class="text-sm font-medium">Apellidos</span>
              <input required name="apellidos" autocomplete="family-name" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
            </label>
          </div>
          <label class="block">
            <span class="text-sm font-medium">Correo</span>
            <input required type="email" name="email" autocomplete="email" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
          </label>
          <label class="block">
            <span class="text-sm font-medium">Dirección</span>
            <input required name="direccion" autocomplete="street-address" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
          </label>
          <div class="grid gap-4 sm:grid-cols-3">
            <label class="block sm:col-span-1">
              <span class="text-sm font-medium">C.P.</span>
              <input required name="cp" autocomplete="postal-code" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
            </label>
            <label class="block sm:col-span-2">
              <span class="text-sm font-medium">Ciudad</span>
              <input required name="ciudad" autocomplete="address-level2" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
            </label>
          </div>
        </fieldset>

        <fieldset class="grid gap-3">
          <legend class="font-display text-2xl font-semibold text-forest-700">Pago</legend>
          <!-- Campos visuales (no funcionales) — el pago real lo gestiona Stripe -->
          <label class="block">
            <span class="text-sm font-medium">Número de tarjeta</span>
            <input inputmode="numeric" placeholder="4242 4242 4242 4242" class="mt-1.5 w-full rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
          </label>
          <div class="grid grid-cols-2 gap-4">
            <input placeholder="MM / AA" class="rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
            <input placeholder="CVC" class="rounded-xl border border-cream-200 bg-white px-4 py-3 outline-none focus:border-forest-500" />
          </div>
        </fieldset>

        <button type="submit" class="rounded-full bg-forest-600 px-8 py-4 text-center font-medium text-white transition-colors hover:bg-forest-700">
          Realizar pedido (simulado)
        </button>
      </form>

      <!-- Resumen del pedido -->
      <aside class="lg:sticky lg:top-24 lg:h-fit">
        <div class="rounded-3xl border border-cream-200 bg-white p-6">
          <h2 class="font-display text-2xl font-semibold text-forest-700">Tu pedido</h2>
          <div id="summary-lines" class="mt-4 divide-y divide-cream-200 text-sm"></div>
          <dl class="mt-5 space-y-2 border-t border-cream-200 pt-5 text-sm">
            <div class="flex justify-between"><dt class="text-ink-soft">Subtotal</dt><dd id="sum-subtotal">—</dd></div>
            <div class="flex justify-between"><dt class="text-ink-soft">Envío</dt><dd id="sum-shipping">—</dd></div>
            <div class="flex justify-between pt-2 text-lg font-semibold"><dt>Total</dt><dd id="sum-total" class="font-display">—</dd></div>
          </dl>
        </div>
      </aside>
    </div>

    <!-- Mensaje de éxito -->
    <div id="success" class="hidden">
      <div class="mx-auto mt-10 max-w-lg rounded-3xl border border-forest-500/30 bg-forest-50 p-8 text-center">
        <div class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-forest-600 text-white">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h2 class="mt-5 font-display text-3xl font-semibold text-forest-700">¡Pedido confirmado!</h2>
        <p class="mt-3 text-ink-soft">
          Gracias por tu compra (simulada). Te habríamos enviado la confirmación por correo.
        </p>
        <a href="/tienda" class="mt-6 inline-flex rounded-full bg-forest-600 px-7 py-3 font-medium text-white hover:bg-forest-700">
          Volver a la tienda
        </a>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ freeFrom: site.freeShippingFrom }}>
    // Espera a que cart.ts registre window.RVCart.
    function init() {
      const C = window.RVCart;
      if (!C) return setTimeout(init, 50);

      const linesEl = document.getElementById("summary-lines");
      const lines = C.lines();
      const cat = C.products();

      if (lines.length === 0) {
        linesEl.innerHTML = `<p class="py-6 text-center text-ink-soft">Tu carrito está vacío. <a class="underline" href="/tienda">Ir a la tienda</a></p>`;
        document.getElementById("checkout-form").classList.add("opacity-50", "pointer-events-none");
      } else {
        linesEl.innerHTML = lines.map((l) => {
          const p = cat[l.slug];
          return `<div class="flex items-center gap-3 py-3">
            <img src="${p.image}" alt="" width="48" height="48" class="h-12 w-12 rounded-lg object-cover"/>
            <div class="flex-1"><p class="font-medium text-ink">${p.name}</p><p class="text-ink-soft">Cantidad: ${l.qty}</p></div>
            <span class="font-medium">${C.fmt(p.price * l.qty)}</span>
          </div>`;
        }).join("");
      }

      const subtotal = C.subtotal();
      const shipping = subtotal >= freeFrom || subtotal === 0 ? 0 : 3.95;
      document.getElementById("sum-subtotal").textContent = C.fmt(subtotal);
      document.getElementById("sum-shipping").textContent = shipping === 0 ? "Gratis" : C.fmt(shipping);
      document.getElementById("sum-total").textContent = C.fmt(subtotal + shipping);

      const form = document.getElementById("checkout-form");
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        if (!form.checkValidity()) return form.reportValidity();
        C.clear();
        form.closest("section").querySelectorAll("form, aside, h1").forEach((el) => el.classList.add("hidden"));
        document.getElementById("success").classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    }
    init();
  </script>
</BaseLayout>
