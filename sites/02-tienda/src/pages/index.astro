---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import { site } from "../data/site";
import { products, categories } from "../data/products";

const featured = products.filter((p) => p.featured);

const values = [
  { title: "Ingredientes botánicos", text: "Fórmulas cortas, sin siliconas ni parabenos." },
  { title: "Lotes pequeños", text: "Elaboración a mano en nuestro taller de Girona." },
  { title: "Envase consciente", text: "Vidrio y aluminio recargables. Cero plástico." },
];

const heroImg =
  "https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?auto=format&fit=crop&w=1600&q=70";
---

<BaseLayout>
  <!-- HERO -->
  <section class="mx-auto grid max-w-6xl items-center gap-10 px-5 pb-8 pt-10 sm:px-8 md:grid-cols-2 md:pt-16">
    <div class="reveal">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-forest-600">Cosmética natural</p>
      <h1 class="mt-4 font-display text-5xl font-semibold leading-[1.02] text-ink sm:text-6xl">
        La piel también <br class="hidden sm:block" />respira mejor <em class="text-forest-600">en verde</em>
      </h1>
      <p class="mt-5 max-w-md text-lg text-ink-soft">
        {site.description}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/tienda" class="rounded-full bg-forest-600 px-7 py-3.5 font-medium text-white transition-transform hover:-translate-y-0.5 hover:bg-forest-700">
          Ver la tienda
        </a>
        <a href="#destacados" class="rounded-full border border-cream-200 px-7 py-3.5 font-medium text-ink transition-colors hover:bg-cream-100">
          Best sellers
        </a>
      </div>
      <p class="mt-5 text-sm text-ink-soft">
        ✦ Envío gratis a partir de {site.freeShippingFrom} € · Hecho en España
      </p>
    </div>
    <div class="reveal overflow-hidden rounded-3xl bg-cream-100">
      <img
        src={heroImg}
        alt="Producto de cosmética natural sobre fondo neutro"
        fetchpriority="high"
        width="1600"
        height="1400"
        class="aspect-[7/6] w-full object-cover"
      />
    </div>
  </section>

  <!-- VALORES -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <div class="grid gap-6 rounded-3xl bg-forest-900 p-8 text-cream-50 sm:grid-cols-3 sm:p-10">
      {
        values.map((v) => (
          <div class="reveal">
            <h2 class="font-display text-2xl font-semibold text-white">{v.title}</h2>
            <p class="mt-2 text-sm text-cream-100/80">{v.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- DESTACADOS -->
  <section id="destacados" class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <header class="reveal flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-forest-600">Favoritos</p>
        <h2 class="mt-2 font-display text-4xl font-semibold sm:text-5xl">Los más queridos</h2>
      </div>
      <a href="/tienda" class="hidden shrink-0 text-sm font-medium text-forest-700 underline hover:text-forest-900 sm:block">
        Ver todo
      </a>
    </header>
    <div class="mt-8 grid grid-cols-2 gap-x-5 gap-y-9 md:grid-cols-4">
      {featured.map((p) => <ProductCard product={p} />)}
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <div class="grid gap-4 sm:grid-cols-3">
      {
        categories.map((c) => (
          <a
            href={`/tienda#${c.id}`}
            class="reveal group flex flex-col justify-between rounded-3xl border border-cream-200 bg-white p-7 transition-colors hover:border-forest-500"
          >
            <div>
              <h3 class="font-display text-2xl font-semibold text-forest-700">{c.label}</h3>
              <p class="mt-2 text-sm text-ink-soft">{c.blurb}</p>
            </div>
            <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-ink group-hover:gap-3 transition-all">
              Explorar
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 12h14m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- NOSOTROS -->
  <section id="nosotros" class="mx-auto grid max-w-6xl items-center gap-10 px-5 py-16 sm:px-8 md:grid-cols-2">
    <div class="reveal order-2 overflow-hidden rounded-3xl bg-cream-100 md:order-1">
      <img
        src="https://images.unsplash.com/photo-1556228841-a3c527ebefe5?auto=format&fit=crop&w=1100&q=70"
        alt="Elaboración artesanal de cosmética"
        loading="lazy"
        width="1100"
        height="1200"
        class="aspect-[11/12] w-full object-cover"
      />
    </div>
    <div class="reveal order-1 md:order-2">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-forest-600">Nuestra historia</p>
      <h2 class="mt-2 font-display text-4xl font-semibold sm:text-5xl">De la planta al tarro</h2>
      <p class="mt-5 leading-relaxed text-ink-soft">
        Empezamos en una cocina, mezclando aceites para la piel sensible de la familia.
        Hoy seguimos igual de cabezotas: fórmulas cortas, ingredientes que sabes pronunciar
        y ni un gramo de relleno. Cada producto se elabora, etiqueta y envía a mano.
      </p>
      <p class="mt-4 leading-relaxed text-ink-soft">
        Trabajamos con productores locales y compensamos la huella de cada envío.
      </p>
      <a href="/tienda" class="mt-7 inline-flex rounded-full border border-forest-500 px-7 py-3 font-medium text-forest-700 transition-colors hover:bg-forest-50">
        Descubre la gama
      </a>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="mx-auto max-w-6xl px-5 pb-16 sm:px-8">
    <div class="reveal rounded-3xl bg-forest-600 px-6 py-12 text-center text-white sm:px-10">
      <h2 class="font-display text-3xl font-semibold sm:text-4xl">Únete al club Raíz Verde</h2>
      <p class="mx-auto mt-3 max-w-md text-cream-100/90">
        10 % en tu primer pedido y rituales de cuidado en tu correo. Sin spam.
      </p>
      <!-- Conectable a Formspree / Mailchimp — ver INTEGRACIONES.md -->
      <form
        action="https://formspree.io/f/mojglkgp"
        method="POST"
        class="mx-auto mt-6 flex max-w-md flex-col gap-3 sm:flex-row"
      >
        <label class="sr-only" for="email">Tu correo</label>
        <input
          id="email" type="email" name="email" required placeholder="tu@correo.com"
          class="w-full rounded-full border border-white/20 bg-white/10 px-5 py-3 text-white placeholder-white/60 outline-none focus:border-white"
        />
        <button type="submit" class="shrink-0 rounded-full bg-cream-50 px-7 py-3 font-medium text-forest-700 hover:bg-white">
          Suscribirme
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
