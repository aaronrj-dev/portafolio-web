---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import { products, formatPrice, categories } from "../../data/products";
import { site } from "../../data/site";

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product: p } = Astro.props;
const cat = categories.find((c) => c.id === p.category);
const images = p.gallery && p.gallery.length ? p.gallery : [p.image];
const related = products.filter((r) => r.category === p.category && r.slug !== p.slug).slice(0, 4);
const fullStars = Math.round(p.rating);
---

<BaseLayout title={p.name} description={p.short}>
  <!-- Migas de pan -->
  <nav aria-label="Migas de pan" class="mx-auto max-w-6xl px-5 pt-8 text-sm text-ink-soft sm:px-8">
    <ol class="flex flex-wrap items-center gap-2">
      <li><a href="/" class="hover:text-forest-700">Inicio</a></li>
      <li aria-hidden="true">/</li>
      <li><a href={`/tienda#${p.category}`} class="hover:text-forest-700">{cat?.label}</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-ink">{p.name}</li>
    </ol>
  </nav>

  <section class="mx-auto grid max-w-6xl gap-10 px-5 py-8 sm:px-8 md:grid-cols-2">
    <!-- Galería -->
    <div class="reveal">
      <div class="overflow-hidden rounded-3xl bg-cream-100">
        <img
          id="hero-img"
          src={images[0]}
          alt={p.name}
          fetchpriority="high"
          width="900"
          height="900"
          class="aspect-square w-full object-cover"
        />
      </div>
      {
        images.length > 1 && (
          <div class="mt-3 flex gap-3">
            {images.map((img, i) => (
              <button
                type="button"
                data-thumb={img}
                class="h-20 w-20 overflow-hidden rounded-xl border-2 border-transparent transition-colors data-[active]:border-forest-500"
                data-active={i === 0 ? "" : undefined}
                aria-label={`Ver imagen ${i + 1}`}
              >
                <img src={img} alt="" width="80" height="80" class="h-full w-full object-cover" />
              </button>
            ))}
          </div>
        )
      }
    </div>

    <!-- Info -->
    <div class="reveal">
      {p.badge && <span class="inline-block rounded-full bg-forest-50 px-3 py-1 text-xs font-medium text-forest-700">{p.badge}</span>}
      <h1 class="mt-3 font-display text-4xl font-semibold leading-tight sm:text-5xl">{p.name}</h1>

      <div class="mt-3 flex items-center gap-2 text-sm text-ink-soft">
        <span class="text-clay-500" aria-hidden="true">{"★".repeat(fullStars)}{"☆".repeat(5 - fullStars)}</span>
        <span>{p.rating.toFixed(1)} · {p.reviews} reseñas</span>
      </div>

      <p class="mt-5 flex items-baseline gap-3">
        <span class="font-display text-3xl font-semibold text-ink">{formatPrice(p.price, site.currency)}</span>
        {p.compareAt && <span class="text-lg text-ink-soft line-through">{formatPrice(p.compareAt, site.currency)}</span>}
        <span class="text-sm text-ink-soft">· {p.size}</span>
      </p>

      <p class="mt-5 leading-relaxed text-ink-soft">{p.description}</p>

      <!-- Cantidad + añadir -->
      <div class="mt-7 flex flex-wrap items-center gap-3">
        <div class="inline-flex items-center rounded-full border border-cream-200 bg-white">
          <button type="button" data-qty-step="-1" class="grid h-12 w-12 place-items-center text-xl text-ink-soft hover:text-ink" aria-label="Restar">−</button>
          <input
            data-qty-input
            type="number" min="1" value="1" inputmode="numeric"
            class="w-12 border-none bg-transparent text-center text-lg outline-none [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none"
            aria-label="Cantidad"
          />
          <button type="button" data-qty-step="1" class="grid h-12 w-12 place-items-center text-xl text-ink-soft hover:text-ink" aria-label="Sumar">+</button>
        </div>
        <button
          type="button"
          data-add-to-cart={p.slug}
          class="flex-1 rounded-full bg-forest-600 px-8 py-3.5 font-medium text-white transition-colors hover:bg-forest-700"
        >
          Añadir al carrito
        </button>
      </div>

      <p class="mt-4 text-sm text-ink-soft">
        ✦ Envío gratis desde {site.freeShippingFrom} € · Devoluciones en 30 días
      </p>

      <!-- Ingredientes -->
      <details class="mt-7 border-t border-cream-200 pt-5">
        <summary class="cursor-pointer font-medium text-ink">Ingredientes (INCI)</summary>
        <p class="mt-2 text-sm leading-relaxed text-ink-soft">{p.ingredients}</p>
      </details>
    </div>
  </section>

  {
    related.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
        <h2 class="reveal font-display text-3xl font-semibold sm:text-4xl">También te puede gustar</h2>
        <div class="mt-7 grid grid-cols-2 gap-x-5 gap-y-9 md:grid-cols-4">
          {related.map((r) => (
            <ProductCard product={r} />
          ))}
        </div>
      </section>
    )
  }

  <script>
    // Stepper de cantidad
    const input = document.querySelector<HTMLInputElement>("[data-qty-input]");
    document.querySelectorAll<HTMLButtonElement>("[data-qty-step]").forEach((btn) => {
      btn.addEventListener("click", () => {
        if (!input) return;
        const step = Number(btn.dataset.qtyStep);
        input.value = String(Math.max(1, (parseInt(input.value, 10) || 1) + step));
      });
    });

    // Galería de miniaturas
    const hero = document.querySelector<HTMLImageElement>("#hero-img");
    document.querySelectorAll<HTMLButtonElement>("[data-thumb]").forEach((thumb) => {
      thumb.addEventListener("click", () => {
        if (!hero) return;
        hero.src = thumb.dataset.thumb!;
        document.querySelectorAll("[data-thumb]").forEach((t) => t.removeAttribute("data-active"));
        thumb.setAttribute("data-active", "");
      });
    });
  </script>
</BaseLayout>
