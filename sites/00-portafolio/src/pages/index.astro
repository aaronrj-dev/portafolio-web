---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Mascot from "../components/Mascot.astro";
import { site, about, services, steps, stack, projects, testimonials } from "../data/site";

const domain = (url: string) => url.replace(/^https?:\/\//, "");
---

<BaseLayout>
  <span id="top"></span>
  <Header />

  <main id="main">
    <!-- ================= HERO ================= -->
    <section class="relative overflow-hidden bg-night-900 text-white">
      <!-- Glow de marca -->
      <div class="pointer-events-none absolute -top-40 left-1/2 h-[520px] w-[820px] -translate-x-1/2 rounded-full opacity-40 blur-3xl"
           style="background: radial-gradient(closest-side, #6366f1, transparent);"></div>
      <div class="pointer-events-none absolute -right-32 top-40 h-[360px] w-[360px] rounded-full opacity-30 blur-3xl"
           style="background: radial-gradient(closest-side, #7c3aed, transparent);"></div>

      <div class="relative mx-auto flex min-h-[90vh] max-w-6xl flex-col justify-center px-5 py-28 sm:px-8">
        <p class="reveal inline-flex w-fit items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm text-slate-300">
          <span class="h-2 w-2 rounded-full bg-green-400"></span>
          Disponible para nuevos proyectos
        </p>
        <h1 class="reveal mt-6 max-w-4xl font-display text-4xl font-semibold leading-[1.08] sm:text-6xl">
          Desarrollo webs rápidas, cuidadas y hechas para <span class="text-gradient">dar confianza</span>.
        </h1>
        <p class="reveal mt-6 max-w-2xl text-lg text-slate-300">{site.sub}</p>
        <div class="reveal mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="#proyectos" class="rounded-full bg-brand-600 px-8 py-3.5 text-center font-medium text-white shadow-lg shadow-brand-600/25 transition-transform hover:-translate-y-0.5 hover:bg-brand-500">
            Ver mis proyectos
          </a>
          <a href="#contacto" class="rounded-full border border-white/25 px-8 py-3.5 text-center font-medium text-white transition-colors hover:bg-white/10">
            Hablemos de tu web
          </a>
        </div>
      </div>
    </section>

    <!-- ================= SOBRE MÍ ================= -->
    <section id="sobre-mi" class="mx-auto max-w-5xl px-5 py-20 sm:px-8 sm:py-28">
      <div class="grid items-start gap-10 md:grid-cols-[auto_1fr]">
        <!-- Avatar: mascota de marca (bichito). Ver components/Mascot.astro -->
        <div class="reveal group relative mx-auto grid h-32 w-32 place-items-center overflow-hidden rounded-3xl bg-night-900 md:mx-0">
          <div class="pointer-events-none absolute inset-0 opacity-60"
               style="background: radial-gradient(closest-side at 50% 40%, rgba(124,58,237,.45), transparent);"></div>
          <Mascot class="relative h-24 w-24 transition-transform duration-500 group-hover:-translate-y-1" />
        </div>
        <div class="reveal">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-brand-600">Sobre mí</p>
          <h2 class="mt-2 font-display text-4xl font-semibold sm:text-5xl">Hola, soy Aaron</h2>
          <div class="mt-6 space-y-5 text-lg leading-relaxed text-ink-soft">
            {about.map((p) => <p>{p}</p>)}
          </div>
        </div>
      </div>
    </section>

    <!-- ================= STACK ================= -->
    <section class="bg-night-900 py-16 text-white sm:py-20">
      <div class="mx-auto max-w-6xl px-5 text-center sm:px-8">
        <p class="reveal text-sm font-medium uppercase tracking-[0.2em] text-brand-300">Tecnologías</p>
        <h2 class="reveal mt-3 font-display text-3xl font-semibold sm:text-4xl">Con lo que trabajo</h2>
        <div class="reveal mt-8 flex flex-wrap justify-center gap-3">
          {
            stack.map((t) => (
              <span class="rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-slate-200">
                {t}
              </span>
            ))
          }
        </div>
        <p class="reveal mt-6 text-sm text-slate-400">Y las tecnologías web modernas que encajen en cada proyecto.</p>
      </div>
    </section>

    <!-- ================= PROYECTOS ================= -->
    <section id="proyectos" class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <header class="reveal max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-brand-600">Proyectos</p>
        <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Echa un vistazo a mi trabajo</h2>
        <p class="mt-4 text-ink-soft">
          Marcas ficticias creadas para enseñar de lo que soy capaz. Cada una es una web real,
          rápida y lista para producción. <strong class="font-medium text-ink">Haz clic para verlas en vivo.</strong>
        </p>
      </header>

      <div class="mt-12 grid gap-7 md:grid-cols-3">
        {
          projects.map((p) => (
            <a
              href={p.live}
              target="_blank"
              rel="noopener"
              aria-label={`Ver en vivo: ${p.title}`}
              class="reveal group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:border-brand-400 hover:shadow-xl"
            >
              {/* Marco de navegador: hace que se lea como una web de verdad */}
              <div class="flex items-center gap-1.5 border-b border-slate-200 bg-slate-100 px-4 py-2.5">
                <span class="h-2.5 w-2.5 rounded-full bg-slate-300" />
                <span class="h-2.5 w-2.5 rounded-full bg-slate-300" />
                <span class="h-2.5 w-2.5 rounded-full bg-slate-300" />
                <span class="ml-2 truncate rounded-md bg-white px-3 py-1 text-xs text-ink-soft">{domain(p.live)}</span>
              </div>
              <div class="relative overflow-hidden">
                <img
                  src={p.image}
                  alt={p.alt}
                  loading="lazy"
                  decoding="async"
                  width="1000"
                  height="667"
                  class="aspect-[3/2] w-full object-cover object-top"
                />
                <span class:list={["absolute left-3 top-3 rounded-full px-3 py-1 text-xs font-medium text-white shadow", p.accent]}>
                  {p.type}
                </span>
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-2xl font-semibold text-ink">{p.title}</h3>
                <p class="mt-2 flex-1 text-ink-soft">{p.blurb}</p>
                <span class="mt-5 inline-flex items-center gap-2 font-medium text-brand-600 transition-all group-hover:gap-3">
                  Ver en vivo
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ================= SERVICIOS ================= -->
    <section id="servicios" class="border-y border-slate-200 bg-slate-100/60 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <header class="reveal max-w-2xl">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-brand-600">Qué hago</p>
          <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Lo que puedo construir para ti</h2>
        </header>
        <div class="mt-12 grid gap-5 sm:grid-cols-2">
          {
            services.map((s, i) => (
              <article class="reveal group rounded-3xl border border-slate-200 bg-white p-7 transition-colors hover:border-brand-400">
                <span class="font-display text-sm font-semibold text-brand-500">0{i + 1}</span>
                <h3 class="mt-2 font-display text-2xl font-semibold text-ink">{s.title}</h3>
                <p class="mt-2 text-ink-soft">{s.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= CÓMO TRABAJO ================= -->
    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <header class="reveal max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-brand-600">Cómo trabajo</p>
        <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Un proceso claro, sin sorpresas</h2>
      </header>
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((s) => (
            <div class="reveal">
              <p class="font-display text-4xl font-semibold text-slate-200">{s.n}</p>
              <h3 class="mt-2 font-display text-xl font-semibold text-ink">{s.title}</h3>
              <p class="mt-1.5 text-ink-soft">{s.text}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ================= TESTIMONIOS ================= -->
    <section class="border-y border-slate-200 bg-slate-100/60 py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-5 sm:px-8">
        <header class="reveal max-w-2xl">
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-brand-600">Testimonios</p>
          <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Lo que dicen de trabajar conmigo</h2>
        </header>
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {
            testimonials.map((t) => (
              <figure class="reveal flex flex-col rounded-3xl border border-slate-200 bg-white p-7">
                <div class="text-brand-500" aria-hidden="true">★★★★★</div>
                <blockquote class="mt-4 flex-1 text-ink-soft">“{t.quote}”</blockquote>
                <figcaption class="mt-6 text-sm">
                  <p class="font-medium text-ink">{t.author}</p>
                  <p class="text-ink-soft">{t.detail}</p>
                </figcaption>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ================= CONTACTO ================= -->
    <section id="contacto" class="mx-auto max-w-2xl px-5 py-20 sm:px-8 sm:py-28">
      <header class="reveal text-center">
        <h2 class="font-display text-4xl font-semibold sm:text-5xl">¿Tienes un proyecto en mente?</h2>
        <p class="mt-4 text-ink-soft">Cuéntame qué necesitas y te respondo lo antes posible. Sin compromiso.</p>
      </header>

      <!-- Formulario listo para Formspree (ver INTEGRACIONES.md) -->
      <form action="https://formspree.io/f/your-form-id" method="POST" class="reveal mt-10 grid gap-5">
        <label class="block">
          <span class="text-sm font-medium text-ink">Nombre</span>
          <input type="text" name="nombre" required autocomplete="name" class="mt-1.5 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 outline-none focus:border-brand-500" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink">Email</span>
          <input type="email" name="email" required autocomplete="email" class="mt-1.5 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 outline-none focus:border-brand-500" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-ink">Mensaje</span>
          <textarea name="mensaje" rows="4" required placeholder="Cuéntame un poco sobre tu negocio y qué necesitas…" class="mt-1.5 w-full rounded-xl border border-slate-200 bg-white px-4 py-3 outline-none focus:border-brand-500"></textarea>
        </label>
        <button type="submit" class="rounded-full bg-brand-600 px-8 py-4 font-medium text-white shadow-lg shadow-brand-600/20 transition-transform hover:-translate-y-0.5 hover:bg-brand-500">
          Enviar mensaje
        </button>
      </form>

      <div class="reveal mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-center text-sm text-ink-soft">
        <a href={`mailto:${site.email}`} class="font-medium text-ink hover:text-brand-600">{site.email}</a>
        <a href={site.github} rel="noopener" target="_blank" class="hover:text-brand-600">{site.githubHandle}</a>
        <a href={site.linkedin} rel="noopener" target="_blank" class="hover:text-brand-600">LinkedIn</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
