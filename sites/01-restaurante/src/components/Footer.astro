---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="bg-marine-900 text-sand-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:px-8 md:grid-cols-3">
    <div>
      <p class="font-display text-2xl font-semibold text-white">{site.name}</p>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-sand-100/80">
        {site.tagline}. En el corazón del Cabanyal.
      </p>
    </div>

    <div class="text-sm">
      <h2 class="font-medium text-white">Contacto</h2>
      <ul class="mt-3 space-y-2 text-sand-100/80">
        <li>
          <a class="hover:text-white" href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </li>
        <li>
          <a class="hover:text-white" href={`mailto:${site.email}`}>{site.email}</a>
        </li>
        <li>{site.address.street}, {site.address.city}</li>
      </ul>
      <div class="mt-4 flex gap-4">
        <a href={site.social.instagram} class="hover:text-white" aria-label="Instagram" rel="noopener" target="_blank">Instagram</a>
        <a href={site.social.facebook} class="hover:text-white" aria-label="Facebook" rel="noopener" target="_blank">Facebook</a>
      </div>
    </div>

    <div class="text-sm">
      <h2 class="font-medium text-white">Horario</h2>
      <ul class="mt-3 space-y-1.5 text-sand-100/80">
        {
          site.hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.d}</span>
              <span class="text-right">{h.h}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-5 text-xs text-sand-100/60 sm:flex-row sm:px-8">
      <p>© {year} {site.name}. Todos los derechos reservados.</p>
      <p>
        Diseño y desarrollo ·
        <a href="mailto:aaronrj.webdev@gmail.com" class="underline hover:text-white">Aaron RJ</a>
      </p>
    </div>
  </div>
</footer>
